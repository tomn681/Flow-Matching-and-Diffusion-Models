{
  "training": {
    "data_root": "/home/data/LDCT",
    "split_file": "/home/data/LDCT/LDCT/AttentionDataset/train.txt",
    "dataset": "ldct",
    "output_dir": "checkpoints/ldct_ddpm_attention",
    "train_batch_size": 16,
    "batch_size": 8,
    "eval_batch_size": 8,
    "num_workers": 4,
    "num_epochs": 500,
    "learning_rate": 0.0001,
    "weight_decay": 0.0,
    "gradient_accumulation_steps": 1,
    "lr_warmup_steps": 500,
    "latent_norm": "standardize",
    "scheduler": "ddpm",
    "num_train_timesteps": 1000,
    "num_inference_steps": 1000,
    "conditioning": "attention",
    "channels": 1,
    "img_size": 256,
    "slice_count": 1,
    "load_ldct": true,
    "norm": true,
    "use_tensor_cache": true,
    "save_model_epochs": 10,
    "mixed_precision": "no",
    "seed": 42,
    "save_images": true,
    "save_images_every": 10
  },
  "model": {
    "unet": {
      "sample_size": 256,
      "in_channels": 1,
      "out_channels": 1,
      "layers_per_block": 2,
      "block_out_channels": [
        128,
        128,
        256,
        256,
        512,
        512
      ],
      "down_block_types": [
        "DownBlock2D",
        "DownBlock2D",
        "DownBlock2D",
        "DownBlock2D",
        "AttnDownBlock2D",
        "DownBlock2D"
      ],
      "up_block_types": [
        "UpBlock2D",
        "AttnUpBlock2D",
        "UpBlock2D",
        "UpBlock2D",
        "UpBlock2D",
        "UpBlock2D"
      ],
      "cross_attention_dim": 4,
      "attention_resolutions": [
        16,
        32
      ],
      "cross_attention_resolutions": [
        16,
        32
      ],
      "cross_attention_in_middle": true
    },
    "scheduler": {
      "name": "ddpm",
      "num_train_timesteps": 1000,
      "num_inference_steps": 1000,
      "params": {
        "beta_start": 0.00085,
        "beta_end": 0.012
      }
    },
    "model_type": "diffusion"
  }
}
