{
  "training": {
    "data_root": "data/mnist",
    "dataset": "mnist",
    "output_dir": "checkpoints/mnist_flow_matching_diffusers_nd",
    "train_batch_size": 32,
    "batch_size": 32,
    "eval_batch_size": 32,
    "num_workers": 4,
    "num_epochs": 50,
    "learning_rate": 0.0001,
    "weight_decay": 0.0,
    "gradient_accumulation_steps": 1,
    "lr_warmup_steps": 500,
    "scheduler": "flow_match_euler",
    "num_train_timesteps": 1000,
    "num_inference_steps": 1000,
    "conditioning": "concatenate",
    "channels": 1,
    "img_size": 32,
    "norm": true,
    "save_model_epochs": 5,
    "mixed_precision": "no",
    "seed": 42,
    "save_images": true,
    "save_images_every": 10
  },
  "model": {
    "unet": {
      "unet_impl": "diffusers_nd",
      "sample_size": 32,
      "in_channels": 1,
      "out_channels": 1,
      "layers_per_block": 2,
      "block_out_channels": [64, 128, 128],
      "down_block_types": ["DownBlock2D", "AttnDownBlock2D", "DownBlock2D"],
      "up_block_types": ["UpBlock2D", "AttnUpBlock2D", "UpBlock2D"],
      "attention_resolutions": [16],
      "cross_attention_resolutions": [],
      "emb_activation_before_proj": false
    },
    "scheduler": {
      "name": "flow_match_euler",
      "num_train_timesteps": 1000,
      "num_inference_steps": 1000,
      "params": {}
    },
    "model_type": "flow_matching"
  }
}
